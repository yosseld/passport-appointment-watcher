{
  "name": "passport-watcher",
  "version": "1.0.0",
  "description": "Watches the U.S. passport agency appointment system and alarms the instant a real, bookable slot opens for your own urgent-travel appointment.",
  "main": "watcher.js",
  "bin": {
    "passport-watcher": "watcher.js"
  },
  "scripts": {
    "start": "node watcher.js",
    "test-alarm": "node watcher.js --test",
    "build": "caxa --input . --output passport-watcher.exe --exclude .git -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/watcher.js\""
  },
  "keywords": [
    "passport",
    "appointment",
    "watcher",
    "notifier",
    "ntfy",
    "travel"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "caxa": "^3.0.1"
  }
}
